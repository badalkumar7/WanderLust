<% layout("/layouts/boilerplate") %>

    <div class="row mt-3">
    <div class="col-8 offset-2" >
    <h3>Edit your Listing</h3>
    <form action="/listings/<%= listing._id %>/edit?_method=PUT" method="POST">
        <div class="mb-3">
            <label for="title" class="form-lable">Title</label>
            <input  type="text" name="listing[title]" value="<%= listing.title %>" class="form-control">
        </div>
        <div class="mb-3">
            <label for="description" class="form-lable">Description</label>
            <textarea rows="8" cols="30" name="listing[description]" class="form-control"><%= listing.description %></textarea>
        </div>
        <div class="mb-3">
            <label for="image" class="form-lable">Image</label>
            <input type="text" name="listing[image.url]" value="<%= listing.image.url %>" class="form-control">
        </div>

        <div class="row">
        <div class="mb-3 col-md-4">
            <label for="price" class="form-lable">Price</label>
            <input type="number" name="listing[price]" value="<%= listing.price %>" class="form-control">
        </div>
        <div class="mb-3 col-md-8">
            <label for="country" class="form-lable">Country</label>
            <input type="text" name="listing[country]" value="<%= listing.country %>" class="form-control">
        </div>
        </div>


        <div class="mb-3">
            <label for="location" class="form-lable">Location</label>
            <input type="text" name="listing[location]" value="<%= listing.location %>" class="form-control">
        </div>
        <button type="submit" class="btn btn-primary add-btn mb-3">edit</button>
    </form>
    </div>
    </div>

